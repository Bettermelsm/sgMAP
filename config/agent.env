# SGA Agent 端配置
# 在运行 Agent 的机器上设置这些环境变量

# ── Hub 连接 ──
SGA_HUB_URL=http://localhost:9527    # 改为 Hub 地址
SGA_API_KEY=                          # 与 Hub 端一致

# ── Agent 身份 ──
AGENT_NAME=my-agent
AGENT_ROLE=worker                     # worker / planner / analyzer / coder
AGENT_CAPABILITIES=python,code_generation

# ── 本地 LLM ──
OLLAMA_BASE=http://localhost:11434
HERMES_MODEL=hermes3
