# SGA Hub 端配置
# 复制此文件为 .env 或直接 export 这些变量

# ── 基础 ──
SGA_PORT=9527
SGA_API_KEY=              # 留空=无鉴权（仅局域网）；公网部署必须设置
HB_TIMEOUT=60
DB_PATH=./platform.db

# ── LLM ──
OLLAMA_BASE=http://localhost:11434
HERMES_MODEL=hermes3

# ── GitHub 共享仓库 ──
SGA_SHARED_REPO=          # 例如 https://github.com/Bettermelsm/SGA_Shared.git
SGA_SHARED_DIR=./shared
GITHUB_WEBHOOK_SECRET=    # 与 GitHub webhook 配置一致

# ── 文件存储 ──
SGA_FILES_DIR=./task_files
MAX_UPLOAD_SIZE_MB=500

# ── 调度器 ──
ORCHESTRATOR_ENABLED=true
ORCHESTRATOR_INTERVAL=5
TASK_STALL_TIMEOUT=300
DEFAULT_MAX_RETRIES=3

# ── 多机互联 ──
SGA_SEED_NODES=           # 逗号分隔，例如 http://node1:9527,http://node2:9527
SGA_PUBLIC_URL=           # 本节点公网地址
