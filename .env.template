# sgMAP 环境变量配置模板
# 复制为 .env 后填入实际值，通过 source .env 或 python-dotenv 加载
# 注意：.env 文件已在 .gitignore 中，不会提交到 GitHub

# ── sgMAP Hub ──────────────────────────────────────────────────────────────
# 注：SGA_* 为现行命名，SGMAP_* 为 V2.1 规范命名，两者等价，SGA_* 优先
SGA_HUB_URL=http://192.168.100.209:9527      # Hub 局域网地址（oracle24G04）
SGA_API_KEY=your-sgmap-api-key-here          # Hub API Key（在 Hub 配置中设置）
# SGMAP_HUB_URL=http://192.168.100.209:9527  # 兼容旧名（可选）
# SGMAP_API_KEY=your-sgmap-api-key-here      # 兼容旧名（可选）

# ── 本地 Ollama（35B 模型所在机器）────────────────────────────────────────
OLLAMA_BASE_URL=http://192.168.100.209:11434
OLLAMA_MODEL=Jarcgon/Qwen3.6-35B-A3B-Claude-4.7-Opus-abliterated-uncenfull
OLLAMA_TIMEOUT=120

# ── MiniMax API（Fallback）────────────────────────────────────────────────
MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY_HERE
MINIMAX_GROUP_ID=YOUR_MINIMAX_GROUP_ID_HERE
MINIMAX_MODEL=abab6.5s-chat
